# =============================================================================
# Next.js — copy to `.env.local` (never commit real secrets)
# =============================================================================

# Spring Boot API origin (no trailing slash).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Public site URL for canonical links, Open Graph, sitemap, and robots.
# In production set this to your real frontend origin, e.g. https://place2prepare.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only: set to 0 to silence `[SSR API] …` lines in the terminal during `next dev`
# (logging is on by default in development for apiRequest from Server Components).
# DEBUG_API=0

# =============================================================================
# Spring Boot — set in the shell, IDE run config, or `.env` for your process
# (this file is for documentation; the JVM does not read .env.local)
# =============================================================================

# Must match NEXT_PUBLIC_SITE_URL for OAuth return URLs and CORS.
APP_FRONTEND_BASE_URL=http://localhost:3000

# Optional overrides (see src/main/resources/application.properties)
# APP_MAX_COURSES_PER_STUDENT=10
# APP_PAYMENTS_ENABLED=true
# APP_PAYMENTS_PROVIDER=mock
# APP_PAYMENTS_PREMIUM_PRICE_INR=999
# APP_PAYMENTS_STRIPE_SECRET_KEY=
# APP_PAYMENTS_STRIPE_WEBHOOK_SECRET=
# APP_NOTIFICATIONS_EMAIL_ENABLED=false
# APP_NOTIFICATIONS_EMAIL_FROM=no-reply@yourdomain.com
